{
  "name": "desktop-hotkeys",
  "version": "0.8.0",
  "description": "DesktopHotkeys — painel de atalhos (launcher overlay) por atalho global no Windows",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "author": "Otavio",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.otavio.desktophotkeys",
    "productName": "DesktopHotkeys",
    "files": [
      "src/**/*",
      "config.example.json",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "portable": {
      "artifactName": "DesktopHotkeys-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "DesktopHotkeys"
    }
  }
}
